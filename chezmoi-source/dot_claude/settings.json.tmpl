{{/* Rendered into ~/.claude/settings.json. Per-user values come from
     .chezmoi.toml.tmpl prompts; shared defaults come from
     .chezmoidata/defaults.yaml.

     We deliberately render lists/maps via toJson to avoid hand-rolled
     comma juggling. The wrapping object is plain text so we can mix
     hand-written keys (theme, model) with templated ones. */ -}}
{
  "autoUpdatesChannel": "latest",
  "theme": "dark",
  "model": "opus",
  "skipDangerousModePermissionPrompt": true,
  "enableAllProjectMcpServers": true,
  "env": {
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "60"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^/autopilot",
        "hooks": [
          {
            "type": "command",
{{- if eq .chezmoi.os "windows" }}
            "command": {{ printf "pwsh -NoProfile -NonInteractive -File \"%s/.claude/hooks/autopilot-arm.ps1\"" (replace "\\" "/" .chezmoi.homeDir) | toJson }},
{{- else }}
            "command": {{ printf "%s/.claude/hooks/autopilot-arm.sh" .chezmoi.homeDir | toJson }},
{{- end }}
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
{{- if eq .chezmoi.os "windows" }}
            "command": {{ printf "pwsh -NoProfile -NonInteractive -File \"%s/.claude/hooks/autopilot-continue.ps1\"" (replace "\\" "/" .chezmoi.homeDir) | toJson }},
{{- else }}
            "command": {{ printf "%s/.claude/hooks/autopilot-continue.sh" .chezmoi.homeDir | toJson }},
{{- end }}
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {{ .claude.defaultPlugins | toJson }},
  "permissions": {
    "allow": {{ .claude.defaultAllowPatterns | toJson }},
    "additionalDirectories": [
      {{ printf "%s/projects" .chezmoi.homeDir | quote }}
    ]
  }
}

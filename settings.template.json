{
  "permissions": {
    "additionalDirectories": [
      "__HOME__/gs-zipline-tej",
      "__HOME__/gs-strategy",
      "__HOME__/gs-auto-fix",
      "__HOME__/quant-research-skill",
      "__HOME__/tutorial"
    ]
  },
  "model": "opus",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "env": {
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "60"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^/autopilot",
        "hooks": [
          {
            "type": "command",
            "command": "__AUTOPILOT_ARM_CMD__",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__AUTOPILOT_HOOK_CMD__",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
